@{
    ViewBag.Title = "About";
}
<main aria-labelledby="title">
    <h2 id="title">Sobre nosotros</h2>
    <h3>Weston</h3>

    <p>
        Fundada en 1990, San José, Costa Rica. Iniciado por nuestro fundador Mario Salas quien hasta la fecha sigue
        fortaleciendo esta gran institución.
    </p>

    <div class="card-group">
        <div class="card">
            <img src="~/Content/imgs/Presentacion1.png" class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">Sedes modernas</h5>
                <p class="card-text">En donde recibirás tus clases.</p>
            </div>
            <div class="card-footer">
                <small class="text-body-secondary">2023</small>
            </div>
        </div>
        <div class="card">
            <img src="~/Content/imgs/personal.jpg" class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">Profesores y estudiantes</h5>
                <p class="card-text">Aprenderán y serán tus mentores durante tu carrera.</p>
            </div>
            <div class="card-footer">
                <small class="text-body-secondary">2023</small>
            </div>
        </div>
        <div class="card">
            <img src="~/Content/imgs/cursosaprende.jpg" class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">Variedad de cursos completos</h5>
                <p class="card-text">Contamos con la carrera de cocina más completa del país.</p>
            </div>
            <div class="card-footer">
                <small class="text-body-secondary">2023</small>
            </div>
        </div>
    </div>

    <br /><br />
    <h3>Localizanos</h3>
    <p>Contamos con sedes en San José, Cartago y Heredia.</p>
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d62879.69464419138!2d-84.11334505!3d9.93554565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e342c50d15c5%3A0xe6746a6a9f11b882!2zU2FuIEpvc8Op!5e0!3m2!1ses-419!2scr!4v1702328990019!5m2!1ses-419!2scr" width="800" height="600" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
</main>