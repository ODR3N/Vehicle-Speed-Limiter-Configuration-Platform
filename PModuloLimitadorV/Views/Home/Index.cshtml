@{
    ViewBag.Title = "Home Page";
}


<!DOCTYPE html>
<html lang="es">
<head>



    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Incluye la hoja de estilos de Fotorama -->
    <link rel="stylesheet" href="lib/fotorama/fotorama.css">

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
        }

        #informacion {
            flex: 2;
            padding: 20px;
        }

        #fotos {
            flex: 1;
            padding: 20px;
        }
    </style>
    <title>Quiénes Somos</title>
</head>
<body>
    <div id="informacion">
        <h2>QUIÉNES SOMOS</h2>
        <p>
            Ingeniería Autotronix S.A. es una empresa dedicada al diagnóstico y reparación de computadoras y paneles electrónicos automotrices. Con más de 15 años de experiencia, brindamos un servicio de calidad gracias a equipo de tecnología de punta y contamos con ingenieros en electrónica, electromecánica y técnicos.

            Le ofrecemos servicio de mensajería para recoger en San José, Heredia, Alajuela, y además encomiendas para todo el país.

            También brindamos soporte a nuestros clientes por medio de consultas técnicas y diagramas eléctricos.
        </p>
    </div>

    <!-- Div para la galería Fotorama -->
    <div id="fotos">
        <!-- Agrega las imágenes de tu galería -->
        <img src="imagen1.jpg" alt="Foto 1">
        <img src="imagen2.jpg" alt="Foto 2">
        <img src="imagen3.jpg" alt="Foto 3">
        <img src="imagen4.jpg" alt="Foto 4">
    </div>

    <!-- Incluye el script de Fotorama y jQuery (necesario para Fotorama) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="lib/fotorama/fotorama.js"></script>
</body>
</html>

